# gRPC-web proxy in front of a lightwalletd instance.
# Browsers cannot speak raw gRPC — run ../../infra/run-testnet-proxy.sh
# to proxy the public testnet lightwalletd (testnet.zec.rocks:443) locally.
NEXT_PUBLIC_LIGHTWALLETD_PROXY=http://localhost:8080

# "test" (Zcash testnet) or "main"
NEXT_PUBLIC_ZCASH_NETWORK=test
